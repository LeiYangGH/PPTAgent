# DeepPresenter configuration
offline_mode: false
context_folding: true
# heavy_reflect: true  # Enable reflective design: render each slide to image and send back to the LLM for visual review

research_agent:
  base_url: "https://openrouter.ai/api/v1"
  model: "anthropic/claude-sonnet-4.5"
  api_key: "your_key"

design_agent:
  base_url: "https://openrouter.ai/api/v1"
  model: "google/gemini-3-pro-preview"
  api_key: "your_key"
  # is_multimodal: true  # Override auto-detection; set to true for multimodal models (e.g. Qwen3-VL, Gemma-3)

long_context_model:
  base_url: "https://open.bigmodel.cn/api/paas/v4/"
  model: "glm-4.5"
  api_key: "your_key"

